<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions required -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <application
        android:allowBackup="false"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.PersonalChat"
        tools:targetApi="m">

        <!-- Splash / Entry Screen -->
        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.PersonalChat.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Onboarding Profile Setup -->
        <activity
            android:name=".ui.onboarding.OnboardingActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.PersonalChat.NoActionBar" />

        <!-- Chats List Screen -->
        <activity
            android:name=".ui.chats.ChatsActivity"
            android:exported="false"
            android:theme="@style/Theme.PersonalChat.NoActionBar" />

        <!-- New Chat Dialog / Screen -->
        <activity
            android:name=".ui.newchat.NewChatActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.PersonalChat.NoActionBar" />

        <!-- Direct 1-to-1 Chat Conversation Screen -->
        <activity
            android:name=".ui.chat.ChatActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.PersonalChat.NoActionBar" />

        <!-- Profile & Settings Screen -->
        <activity
            android:name=".ui.profile.ProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.PersonalChat.NoActionBar" />

    </application>

</manifest>
